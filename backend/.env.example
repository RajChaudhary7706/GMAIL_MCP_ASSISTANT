# Application
APP_NAME=Gmail MCP Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gmail_mcp
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gmail_mcp

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth 2.1
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ChromaDB
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=gmail_emails

# Embedding Config
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
CHUNK_SIZE_PRECISION=256
CHUNK_SIZE_CONTEXTUAL=768
CHUNK_OVERLAP=50

# IMAP IDLE
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_IDLE_TIMEOUT=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000